  m_TableData:
  - m_Id: 324552245248
    m_Localized: "\u041F\u0440\u0438\u0432\u0435\u0442 \u0410\u043D\u044F. \u041D\u0430
      \u0440\u044B\u043D\u043A\u0435 \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442
      \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u043E\u0432, \u043F\u043E\u043C\u043E\u0436\u0435\u0448\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 382584635392
    m_Localized: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u043A\u0430\u043A
      \u0432\u0441\u0435\u0433\u0434\u0430 \u0431\u044B\u0441\u0442\u0440\u043E \u0438
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 450297479168
    m_Localized: "\u041E\u0447\u0435\u043D\u044C \u0436\u0430\u043B\u044C, \u0447\u0442\u043E
      \u0443 \u0442\u0435\u0431\u044F \u043D\u0435 \u0432\u044B\u0448\u043B\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 524494716928
    m_Localized: "\u0441 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0435\u0446
