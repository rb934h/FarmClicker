  m_TableData:
  - m_Id: 347914518528
    m_Localized: "\u041F\u0440\u0438\u0432\u0435\u0442 \u0410\u043D\u043D\u0430,
      \u0432 \u0434\u0435\u0442\u0441\u043A\u043E\u043C \u0434\u043E\u043C\u0435
      \u043F\u0440\u043E\u0442\u0435\u043A\u0430\u0435\u0442 \u043A\u0440\u044B\u0448\u0430,
      \u043D\u0435 \u043C\u043E\u0433\u043B\u0430 \u0431\u044B \u0442\u044B \u043F\u043E\u043C\u043E\u0447\u044C?
      \u0414\u043B\u044F \u0440\u0435\u043C\u043E\u043D\u0442\u0430 \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
      100 \u043C\u043E\u043D\u0435\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 406181789696
    m_Localized: "\u041E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0441\u043F\u0430\u0441\u0438\u0431\u043E,
      \u0434\u0435\u0442\u0438 \u0431\u0443\u0434\u0443\u0442 \u0441\u043F\u0430\u0442\u044C
      \u0432 \u0442\u0435\u043F\u043B\u0435!"
    m_Metadata:
      m_Items: []
  - m_Id: 473395511296
    m_Localized: "\u041D\u0430\u043C \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
      \u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0438\u0442\u044C \u0432\u0441\u0435\u0445
      \u0432 \u0441\u043F\u043E\u0440\u0442\u0437\u0430\u043B \u0448\u043A\u043E\u043B\u044B.
      \u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u0447\u0442\u043E \u0442\u044B
      \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 540256911360
    m_Localized: "\u0441 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440
      \u0412\u0430\u043B\u0435\u0440\u0438\u0439"
